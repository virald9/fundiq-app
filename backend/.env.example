# ═══════════════════════════════════════════════════
# FundIQ Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to git
# ═══════════════════════════════════════════════════

# ── ANTHROPIC (Claude AI) ──────────────────────────
# Get from: https://console.anthropic.com/
# Cost: ~₹0.01 per AI query (pay per use, no monthly fee)
ANTHROPIC_API_KEY=sk-ant-...

# ── RAZORPAY (Subscriptions & Billing) ────────────
# Get from: https://dashboard.razorpay.com/
# Cost: 2% per successful transaction + 18% GST (NO monthly fee)
# Sign up free, only pay when you earn money
RAZORPAY_KEY_ID=rzp_live_...
RAZORPAY_KEY_SECRET=...
RAZORPAY_WEBHOOK_SECRET=...

# These plan IDs come from your Razorpay dashboard
# Create plans at: Dashboard > Subscriptions > Plans
# Premium Monthly: ₹833/month
RZP_PLAN_PREM_MONTHLY=plan_...
# Premium Yearly: ₹5,999/year  
RZP_PLAN_PREM_YEARLY=plan_...
# Pro Monthly: ₹1,399/month
RZP_PLAN_PRO_MONTHLY=plan_...
# Pro Yearly: ₹9,999/year
RZP_PLAN_PRO_YEARLY=plan_...

# ── SERVER ────────────────────────────────────────
PORT=3001
NODE_ENV=production

# ── OPTIONAL: DATABASE ────────────────────────────
# Supabase free tier (500MB, perfect for user data)
# Get from: https://supabase.com (free forever tier)
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_ANON_KEY=eyJ...

# ── OPTIONAL: EMAIL ALERTS ────────────────────────
# Resend.com free tier: 3,000 emails/month free
# Get from: https://resend.com (free tier)
RESEND_API_KEY=re_...
FROM_EMAIL=alerts@fundiq.in
